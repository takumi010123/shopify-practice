<section class="hero" style="background-color: {{ section.settings.bg_color }};">
  <h1 class="hero__title">{{ section.settings.heading }}</h1>
  <p class="hero__text">{{ section.settings.text }}</p>
</section>

{% schema %}
  {
    "name": "ヒーロー",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "見出し",
        "default": "毎朝に、一杯のしあわせを。"
      },
      {
        "type": "textarea",
        "id": "text",
        "label": "サブテキスト",
        "default": "自家焙煎したコーヒー豆を、焙煎したてでお届けします。"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "背景色",
        "default": "#efe7dc"
      }
    ]
  }
{% endschema %}