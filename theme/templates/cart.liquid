{% if cart.item_count == 0 %}

  <section class="cart cart--empty">
    <h1>カートは空です</h1>
    <a href="/">買い物を続ける</a>
  </section>

{% else %}

  <section class="cart">
    <h1>カート</h1>
    {% form 'cart', cart %}
      {% for item in cart.items %}
        <div class="cart-item">
          <a href="{{ item.url }}" class="cart-item__link">
            <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}" width="100" height="100">
            <div class="cart-item__info">
              <span class="cart-item__title">{{ item.product.title }}</span>
              {% unless item.product.has_only_default_variant %}
                <span class="cart-item__variant">{{ item.variant.title }}</span>
              {% endunless %}
            </div>
          </a>
          <div class="cart-item__qty">
            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn">−</a>
            <span class="qty-value">{{ item.quantity }}</span>
            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn">＋</a>
          </div>
          <span class="cart-item__price">{{ item.final_line_price | money }}</span>
          <a href="{{ item.url_to_remove }}" class="cart-item__remove">削除</a>
        </div>
      {% endfor %}

      <p class="cart__total">合計: {{ cart.total_price | money }}</p>
      <button type="submit" name="checkout" class="cart__checkout">レジに進む</button>
    {% endform %}
  </section>
{% endif %}